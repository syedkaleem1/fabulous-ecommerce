# Copy to .env and fill in real values before running docker-compose

# Database password (shared across all MySQL containers)
#DB_PASS=change_me_in_prod

# JWT — must be the same secret in api-gateway and order-service
#JWT_SECRET=change_me_to_a_long_random_string_in_prod

# Stripe keys — get from https://dashboard.stripe.com/apikeys
#STRIPE_API_KEY=sk_test_REPLACE_ME
#STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
